# Shopware Configuration
SHOPWARE_URL=
SW_ACCESS_KEY=
DIFY_API_KEY=
# Dify Configuration
DIFY_URL=https://dify.commerce-crew.com

# Server Configuration
PORT=3330
NODE_ENV=production

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ccchatmiddleware
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# First tenant (seed-tenant.js will use these)
TENANT_NAME=DentalKiosk
TENANT_SLUG=dentalkiosk
TENANT_SUBDOMAIN=
TENANT_API_KEY=cc_change_me

# CORS - Allowed origins (comma-separated)
ALLOWED_ORIGINS=https://dentalkiosk.de,http://localhost:3330,http://localhost:8000

# Cache Settings
CACHE_ENABLED=false
CACHE_TTL=300

# Admin API Key (for cache management)
ADMIN_KEY=your-secure-admin-key-here

# Logging
LOG_LEVEL=combined

DEBUG=true

# Admin Dashboard (Basic Auth)
ADMIN_USER=admin
ADMIN_PASS=change-me
