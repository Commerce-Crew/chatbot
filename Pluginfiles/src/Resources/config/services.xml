<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <defaults autowire="true" autoconfigure="true" public="false" />

        <service id="CommerceCrew\CCChatbot\Service\CmsPageTextExtractor" />

        <service id="CommerceCrew\CCChatbot\Storefront\Controller\ContextController" public="true" />
        <service id="CommerceCrew\CCChatbot\Storefront\Controller\StorePagesController" public="true">
            <argument type="service" id="landing_page.repository" />
            <argument type="service" id="cms_page.repository" />
            <argument type="service" id="category.repository" />
        </service>
    </services>
</container>
