{% sw_extends "@Storefront/storefront/layout/meta.html.twig" %}
{#
  CCChatbot: Context token is never output in HTML.
  The token is obtained securely via XHR from the context controller (path: frontend.ccchatbot.context).
#}

{% block layout_head_inner %}
    {{ parent() }}
    {% set ccEnabled = config('CCChatbot.config.enabled') %}
    {% set visibilityMode = config('CCChatbot.config.visibilityMode') ?: 'everyone' %}
    {% set specificCustomerId = (config('CCChatbot.config.specificCustomerId') ?: '')|trim %}
    {% set isLoggedInCustomer = context.customer is not null %}
    {% set customerIdMatches = specificCustomerId != '' and isLoggedInCustomer and context.customer.id == specificCustomerId %}
    {% set ccVisible = ccEnabled and (
        visibilityMode == 'everyone'
        or (visibilityMode == 'customers_only' and isLoggedInCustomer)
        or (visibilityMode == 'specific_customer' and customerIdMatches)
    ) %}
    {% if ccVisible %}
        {% sw_include '@CCChatbot/storefront/ccchatbot/chatbot.html.twig' %}
    {% endif %}
{% endblock %}
